# YouTube Video Generation Pipeline - Environment Configuration
# Copy this file to .env and fill in your values

# Required - Get from https://platform.openai.com/
OPENAI_API_KEY=sk-...

# Required - Get from https://elevenlabs.io/
ELEVENLABS_API_KEY=...

# Optional - Reddit API (for trend discovery)
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional - YouTube Data API (for trend discovery)
# Get from https://console.cloud.google.com/
YOUTUBE_API_KEY=